+def reset_joints_by_offset_per_joint(
+    env,
+    env_ids: torch.Tensor,
+    position_range_per_joint: dict[str, tuple[float, float]],
+    velocity_range: tuple[float, float] = (0.0, 0.0),
+    asset_cfg: SceneEntityCfg = SceneEntityCfg("robot"),
+):
+    """관절별로 서로 다른 오프셋 범위를 적용해 시작 자세를 무작위화한다 (로컬 추가 2026-07-21).
+
+    표준 `reset_joints_by_offset`은 모든 관절에 같은 범위를 주지만, 교정(recovery) 데이터
+    수집에는 관절별 차등이 필요하다:
+      - Rotation(pan)/Pitch/Elbow: 크게 흔들어 "어긋난 시작"을 만든다
+      - Jaw(gripper): 파지 동작이므로 시작부터 흔들지 않는다(범위 0)
+    목적: 실기 GR00T 실패의 근본 원인이었던 '학습에 없는 어긋난 상태에서의 교정 부재'를
+    sim에서 자동·대량으로 채운다 (report/GR00T_report.md §3.2, sim2real/05 §0.1.1).
+
+    범위 단위는 라디안(관절 오프셋). 지정하지 않은 관절은 오프셋 0.
+    """
+    asset: Articulation = env.scene[asset_cfg.name]
+
+    joint_pos = asset.data.default_joint_pos[env_ids].clone()
+    joint_vel = asset.data.default_joint_vel[env_ids].clone()
+
+    # 관절 이름 → 인덱스 매핑으로 각 관절에 개별 범위 적용
+    for joint_name, (lo, hi) in position_range_per_joint.items():
+        j_ids, _ = asset.find_joints(joint_name)
+        if len(j_ids) == 0:
+            continue
+        j = j_ids[0]
+        offset = math_utils.sample_uniform(lo, hi, (len(env_ids),), joint_pos.device)
+        joint_pos[:, j] += offset
+
+    if velocity_range != (0.0, 0.0):
+        joint_vel += math_utils.sample_uniform(*velocity_range, joint_vel.shape, joint_vel.device)
+
+    # 관절 한계로 클램프 (물리적으로 불가능한 자세 방지)
+    limits = asset.data.soft_joint_pos_limits[env_ids]
+    joint_pos = joint_pos.clamp_(limits[..., 0], limits[..., 1])
+
+    asset.write_joint_state_to_sim(joint_pos, joint_vel, env_ids=env_ids)
+
+
